; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   option = value ; assign values to options

config_version=5

[application]
config/name="Taco Serve"
config/version="3.0"
config/description="TACO SERVE 3.0 - Enhanced 3D horror game with quest system, achievements, sanity mechanics, dialogue, weapons, save system, and comprehensive analytics. Survive the ultimate night shift."
run/main_scene="res://Scenes/UI/MainMenuScene.tscn"
config/features=PackedStringArray("4.3", "3d")
config/icon="res://icon.svg"

[physics]
3d/physics_engine="GodotPhysics3D"

[rendering]
rendering/textures/canvas_textures/default_texture_filter=0
rendering/global_illumination/probe_subdivision=2
rendering/environment/default_clear_color=Color(0.1, 0.1, 0.15, 1)

[audio]
bus_layouts/default="res://Audio/AudioBuses.tres"
